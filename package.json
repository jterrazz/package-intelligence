{
    "name": "@jterrazz/intelligence",
    "version": "5.0.0",
    "author": "Jean-Baptiste Terrazzoni <contact@jterrazz.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/jterrazz/package-intelligence"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        },
        "./text": {
            "require": "./dist/text.cjs",
            "import": "./dist/text.js"
        }
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "lint": "typescript check",
        "lint:fix": "typescript fix",
        "test": "vitest --run"
    },
    "dependencies": {
        "@ai-sdk/openai": "^4.0.14",
        "@jterrazz/telemetry": "^1.1.0",
        "@openrouter/ai-sdk-provider": "^3.0.0",
        "jsonrepair": "^3.15.0",
        "langfuse": "^3.38.20"
    },
    "devDependencies": {
        "@ai-sdk/provider": "^4.0.3",
        "@jterrazz/typescript": "^6.0.1",
        "@types/node": "^26.1.1",
        "ai": "^7.0.28",
        "tsdown": "^0.22.7",
        "vitest": "^4.1.10",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "ai": ">=7.0.0",
        "zod": ">=4.0.0"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        },
        "zod": {
            "optional": true
        }
    }
}
