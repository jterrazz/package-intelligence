{
    "name": "@jterrazz/intelligence",
    "version": "4.2.0",
    "author": "Jean-Baptiste Terrazzoni <contact@jterrazz.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/jterrazz/package-intelligence"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        },
        "./text": {
            "require": "./dist/text.cjs",
            "import": "./dist/text.js"
        }
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "lint": "typescript check",
        "lint:fix": "typescript fix",
        "test": "vitest --run"
    },
    "dependencies": {
        "@ai-sdk/openai": "^3.0.48",
        "@jterrazz/telemetry": "^1.0.0",
        "@openrouter/ai-sdk-provider": "^2.3.3",
        "jsonrepair": "^3.13.3",
        "langfuse": "^3.38.6"
    },
    "devDependencies": {
        "@ai-sdk/provider": "^3.0.8",
        "@jterrazz/test": "^5.3.2",
        "@jterrazz/typescript": "^6.0.0",
        "@types/node": "^25.5.0",
        "ai": "^6.0.140",
        "tsdown": "^0.21.5",
        "vitest": "^4.1.2",
        "zod": "^4.1.11"
    },
    "peerDependencies": {
        "ai": ">=6.0.0",
        "zod": ">=4.0.0"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        },
        "zod": {
            "optional": true
        }
    }
}
